{
  "name": "collegeverse-backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "lint": "echo \"No lint configured\"",
    "build": "echo \"No build step\"",
    "test": "jest -c jest.unit.config.js --runInBand",
    "test:unit": "jest -c jest.unit.config.js --runInBand",
    "test:coverage": "jest -c jest.unit.config.js --runInBand --coverage",
    "test:integration": "firebase emulators:exec --project demo-test --only firestore,auth \"jest -c jest.integration.config.js --runInBand\"",
    "test:watch": "jest -c jest.unit.config.js --watch",
    "firebase:preflight": "NODE_ENV=development node scripts/firebasePreflight.js",
    "seed:demo": "NODE_ENV=development node scripts/seedDemo.js",
    "seed:data": "NODE_ENV=development node scripts/seedDemoData.js",
    "seed:firestore": "NODE_ENV=development node scripts/seedFirestore.js",
    "chain:local": "hardhat node",
    "web3:deploy:local": "hardhat run scripts/hardhat/deploy-local-sbt.cjs --network localhost",
    "chain:anvil": "anvil --host 127.0.0.1 --port 8545",
    "web3:deploy:anvil": "node scripts/anvil/deploy-local-sbt.js"
    ,
    "dev:web3": "node scripts/local-chain/dev-server.cjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "firebase": "^12.9.0",
    "firebase-admin": "^12.2.0",
    "helmet": "^7.1.0",
    "socket.io": "^4.7.5",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.13.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@openzeppelin/contracts": "^5.4.0",
    "firebase-tools": "^13.8.0",
    "hardhat": "^2.22.3",
    "jest": "^29.7.0",
    "solc": "^0.8.33",
    "supertest": "^6.3.4"
  }
}
