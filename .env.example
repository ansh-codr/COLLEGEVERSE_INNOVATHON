# Copy to .env.development, .env.staging, or .env.production as needed.
NODE_ENV=development
PORT=4000
BODY_LIMIT=1mb
TRUST_PROXY=true

# Comma-separated allowed origins.
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Logging
LOG_LEVEL=debug
LOG_DIR=logs
AUTH_REQUIRE_EMAIL_VERIFIED=false

# Observability
SENTRY_DSN=
ALERT_WEBHOOK_URL=
METRICS_LOGGING=true

# Firebase Admin credentials (use either inline or file path)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_STORAGE_BUCKET=

# Local dev convenience: allow starting the server without Firebase Admin.
# WARNING: When true, any endpoints needing Firestore/Auth will fail.
DISABLE_FIREBASE_ADMIN=false

# Optional Firebase Web config
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MEASUREMENT_ID=

# ==========================
# Web3 (Polygon Amoy SBT)
# ==========================
# Polygon Amoy RPC URL (you can use the default public RPC or Alchemy/Infura)
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Admin wallet private key used to mint SBTs (NEVER commit real keys)
ADMIN_WALLET_PRIVATE_KEY=

# Deployed CollegeVerseSBT contract address on Polygon Amoy
SBT_CONTRACT_ADDRESS=

# Optional gas caps for mint transactions (gwei)
# Lower values = cheaper but may confirm slower
MINT_MAX_FEE_GWEI=
MINT_MAX_PRIORITY_GWEI=

# Used to encrypt custodial wallets stored in Firestore (required for production)
WALLET_ENCRYPTION_KEY=
